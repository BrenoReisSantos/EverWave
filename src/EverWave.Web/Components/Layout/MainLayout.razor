@inherits LayoutComponentBase

<MudThemeProvider/>
<MudPopoverProvider/>

@* Needed for dialogs *@
<MudDialogProvider/>

@* Needed for snackbars *@
<MudSnackbarProvider/>

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@ToggleDrawer"/>
        <MudSpacer/>
    </MudAppBar>
    <MudDrawer ClipMode="DrawerClipMode.Docked" @bind-Open="@_open" Elevation="1">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">My App</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavGroup Icon="@Icons.Material.Filled.Settings" Title="Configurações Locais" Expanded="true">
            </MudNavGroup>
            <MudNavGroup Icon="@Icons.Material.Filled.Language" Title="Configurações Globais" Expanded="true">
                <MudNavLink Href="/unidades" Icon="@Icons.Material.Filled.Church">Unidades</MudNavLink>
            </MudNavGroup>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent Class="pt-16 px-16">
        @Body
    </MudMainContent>
</MudLayout>

@code{
    private bool _open = false;

    private void ToggleDrawer()
    {
        _open = !_open;
    }

}